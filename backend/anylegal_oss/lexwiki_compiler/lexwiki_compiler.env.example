# LexWiki compiler — env file for the sidecar container.
# Place this file (chmod 600) where your deployment expects env files.

# === Required ===

# Same value as the backend's ANYLEGAL_ENCRYPTION_KEY. The compiler must
# decrypt workspace_documents to compile them, then re-encrypt the wiki.
ANYLEGAL_ENCRYPTION_KEY=

# OpenRouter — already provisioned for observer/seotracker.
OPENROUTER_API_KEY=

# === LLM ===

# Compile uses the workspace owner's `users.preferred_model` when set —
# CC-style discipline so reads + writes of the wiki use the same model.
# LEXWIKI_MODEL is the FALLBACK when the user has no preference (and for
# operator-side dev runs of `--workspace <id>`).
LEXWIKI_MODEL=moonshotai/kimi-k2.6
# NB: LexWiki appends `/v1/chat/completions` itself, so do NOT include /v1.
LEXWIKI_BASE_URL=https://openrouter.ai/api

# Send :nocollect/data_collection=deny to OpenRouter so prompts/responses
# aren't retained by upstream providers. Default true.
OPENROUTER_ZDR=1

# === Paths ===

# Read-write — compiler writes to workspace_wikis (separate table from
# workspaces, no schema overlap).
LEXWIKI_COMPILER_DB_PATH=./data/anylegal_oss.db

# Compiler scratch dir. Per-workspace subdirs are created and wiped per run.
LEXWIKI_COMPILER_SCRATCH_DIR=/app/scratch

# Heartbeat / status markers (mount path you configure).
LEXWIKI_COMPILER_STATE_DIR=/app/state

# === Scheduling ===

# Loop interval in seconds (between polling passes).
LEXWIKI_COMPILER_POLL_INTERVAL=60

# Don't recompile a workspace if it was edited within this window —
# avoids chasing the user mid-edit.
LEXWIKI_COMPILER_DEBOUNCE_SECONDS=300

# Cap workspaces compiled per pass to bound parallel LLM cost.
LEXWIKI_COMPILER_MAX_PER_PASS=5

# Per-workspace caps (bound cost on pathological inputs).
LEXWIKI_COMPILER_MAX_DOCS=200
LEXWIKI_COMPILER_MAX_DOC_CHARS=200000

# Optional: log level (DEBUG | INFO | WARNING | ERROR).
LOG_LEVEL=INFO
