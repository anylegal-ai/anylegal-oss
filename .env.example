# =============================================================================
# AnyLegal OSS — environment configuration
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.

# -----------------------------------------------------------------------------
# Required: at least one LLM provider
# -----------------------------------------------------------------------------

# OpenRouter — required for any chat to work. Free tier is fine: pay-as-you-go
# credits, no monthly fee, ~$0.01 per typical legal-research turn on a small
# model and a few cents on Claude.
#
# 1. Sign up: https://openrouter.ai/
# 2. Generate a key: https://openrouter.ai/keys
# 3. Paste it on the next line. Without this, the chat composer will return
#    an error on the first message.
OPENROUTER_API_KEY=

# Optional: pin specific provider order for chat / planner endpoints
# Comma-separated provider names, in priority order. Empty = OpenRouter default.
OPENROUTER_PROVIDER_ORDER_CHAT=
OPENROUTER_PROVIDER_ORDER_PLANNER=
OPENROUTER_IGNORE_PROVIDERS=
OPENROUTER_ALLOW_FALLBACKS=true

# Default model (OpenRouter model ID). Override per-workspace in the UI.
DEFAULT_MODEL=anthropic/claude-sonnet-4.5

# -----------------------------------------------------------------------------
# Optional: web search backend
# -----------------------------------------------------------------------------
#
# `web_search` (the agent's research tool) is pluggable. Set EITHER key below
# and you're done. Without one, `web_search` returns "not configured" and the
# agent has no URLs to cite — it'll fall back to memory and citations will
# silently disappear from /research output.
#
# Auto-resolution: SERPER if its key is set, else Brave. Pin a choice with
# SEARCH_PROVIDER=serper|brave when both keys are present.

# SERPER — Google SERP via API. Free tier ~2.5K queries/mo, no card.
# Sign up: https://serper.dev/   |   Get key: https://serper.dev/api-key
SERPER_API_KEY=

# Brave Search API — independent index. Free tier 2K queries/mo, no card.
# Sign up: https://brave.com/search/api/   |   Dashboard: https://api.search.brave.com/app/keys
BRAVE_SEARCH_API_KEY=

# Force a provider when both keys are set. Empty / "auto" = registry order
# (SERPER first, then Brave).
SEARCH_PROVIDER=

# -----------------------------------------------------------------------------
# Storage and runtime paths
# -----------------------------------------------------------------------------

DATABASE_PATH=./data/anylegal_oss.db
LOG_FILE_PATH=./logs/anylegal_oss.log

# Model registry config (JSON file listing approved models). Default ships with
# Kimi K2.6, Kimi K2.5, MiniMax M2.5, DeepSeek V3.2 / V4 Pro, GLM-5 / GLM-5.1,
# Claude Opus 4.7, GPT-5.3 Codex.
MODELS_CONFIG_PATH=./config/models.json

# -----------------------------------------------------------------------------
# Internal service URLs (docker-compose defaults)
# -----------------------------------------------------------------------------

LIBREOFFICE_SERVICE_URL=http://libreoffice-service:8002

# -----------------------------------------------------------------------------
# Server config
# -----------------------------------------------------------------------------

# OSS is single-tenant and unauthenticated. Default bind is loopback only.
# Override to 0.0.0.0 when running behind a reverse proxy that adds auth,
# or inside docker-compose where the bridge network needs an outward bind
# (the compose file already overrides this).
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO

# Frontend dev proxy (used by `next dev`)
FASTAPI_DEV_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------

# The base URL the frontend should call for backend API requests.
# In docker-compose, the frontend container talks to the backend container directly.
# Leave unset / empty for same-origin (typical reverse-proxy production deploy).
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Logging — session transcripts
# -----------------------------------------------------------------------------
#
# When true (default), every chat session writes a JSONL transcript to
# anylegal_sessions/<session_id>.jsonl with full message content (user prompts,
# assistant responses, tool events). Useful for local debugging.
#
# Set to false for sovereignty / procurement deployments where no plaintext
# message content should land on disk. The SQLite copy in agentic_messages
# is governed separately by ANYLEGAL_ENCRYPTION_KEY (see docs/encryption.md).
LOG_TRANSCRIPTS=true

# -----------------------------------------------------------------------------
# Advanced (opt-in): at-rest document encryption
# -----------------------------------------------------------------------------
#
# Off by default. Modern self-hosted deployments rely on full-disk encryption
# (FileVault, BitLocker, LUKS) for the same threat model, so app-layer Fernet
# is usually theater here. Enable only if you have a procurement requirement
# that specifically calls for application-level at-rest encryption.
#
# See docs/encryption.md for the threat model, key generation, key rotation,
# and the operational caveats (lose the key → lose all data).
#
# ANYLEGAL_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Optional: feature flags
# -----------------------------------------------------------------------------

CHAT_ENABLED=true

# Plan mode — model-initiated multi-step planner workflow. The model calls
# `enter_plan_mode` to propose a plan, the user approves it, then the
# planner runs the steps with restricted tools.
#
# Off by default in OSS: the planner output renderer depends on frontend
# state that's still settling, and the kimi-k2.6 default model is not yet
# reliable at the plan-approval handshake. With this flag set to anything
# other than "enabled", `enter_plan_mode` and `exit_plan_mode` are not
# registered for the LLM at all — the model can't invoke plan mode, the
# planner code path stays dormant, no UI surfaces.
#
# Set to "enabled" to surface the planner. After flipping, recreate the
# backend so it re-reads the env: `docker compose up -d --no-deps backend`.
ANYLEGAL_PLANNER_MODE=disabled
